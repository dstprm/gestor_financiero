# Database (Supabase)
DATABASE_URL=""

# Direct connection to the database. Used for migrations
DIRECT_URL=""


# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/app"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/app"

# Dev override: set this to test DB sync before Clerk is configured
# Use any UUID, e.g. your org's ID from Supabase once connected
NEXT_PUBLIC_ORG_ID=

# Payments (Paddle)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""
PADDLE_API_KEY=""
NEXT_PUBLIC_PADDLE_PRICE_ID=""
PADDLE_ENVIRONMENT=""
PADDLE_WEBHOOK_SECRET=""

# Email (Resend)
RESEND_API_KEY=""

# Cron job auth — generate with: openssl rand -hex 32
CRON_SECRET=""

# Public URL of the app (used in email links)
NEXT_PUBLIC_APP_URL=""
