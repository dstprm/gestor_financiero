# Database (Supabase)
DATABASE_URL="postgresql://user:password@host:5432/simplyorg"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/app"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/app"

# Dev override: set this to test DB sync before Clerk is configured
# Use any UUID, e.g. your org's ID from Supabase once connected
NEXT_PUBLIC_ORG_ID=

# Payments (Paddle)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="test_..."
PADDLE_API_KEY="..."
NEXT_PUBLIC_PADDLE_PRICE_ID="pri_..."
PADDLE_ENVIRONMENT="sandbox"
PADDLE_WEBHOOK_SECRET="..."
