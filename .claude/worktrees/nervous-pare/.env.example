# =============================================================================
# ClaudeKit — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase PostgreSQL via Prisma)
# Supabase dashboard → Settings → Database → Connection string
# -----------------------------------------------------------------------------

# Connection pooling URL (used by Prisma at runtime — supports concurrent requests)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (used by Prisma for migrations — bypasses pooler)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# Clerk (Authentication)
# Clerk dashboard → API Keys
# -----------------------------------------------------------------------------

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET="whsec_..."

# Clerk redirect URLs (defaults work for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/auth/redirect"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/auth/redirect"

# -----------------------------------------------------------------------------
# Paddle (Billing)
# Paddle dashboard → Developer Tools → Authentication
# Use Sandbox credentials for development, live credentials for production.
# -----------------------------------------------------------------------------

# Client-side token (safe to expose publicly)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="test_..."

# Server-side API key (keep secret)
PADDLE_API_KEY="..."

# Paddle dashboard → Notifications → Webhooks → your endpoint → Signing Secret
PADDLE_WEBHOOK_SECRET="pdl_ntfset_..."

# Paddle dashboard → Catalog → Prices → your monthly price → Price ID
NEXT_PUBLIC_PADDLE_PRICE_ID="pri_..."

# Set to "sandbox" for development/testing, "production" for live payments.
PADDLE_ENVIRONMENT="sandbox"

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# Full public URL of your app (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourapp.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Display name used in emails and UI copy (default: ClaudeKit)
NEXT_PUBLIC_APP_NAME="ClaudeKit"

# Optional: pin a fixed org ID (single-tenant / demo mode). Leave empty for multi-tenant.
NEXT_PUBLIC_ORG_ID=""

# -----------------------------------------------------------------------------
# Email (Resend) — optional
# If RESEND_API_KEY is not set, emails are logged to console in development.
# resend.com → API Keys
# -----------------------------------------------------------------------------

RESEND_API_KEY=""

# Verified sender address (must match a domain verified in Resend)
EMAIL_FROM="ClaudeKit <noreply@yourdomain.com>"

# -----------------------------------------------------------------------------
# Cron jobs (Vercel Cron)
# Generate a random secret and add it as a Vercel env var.
# Vercel automatically sets Authorization: Bearer <CRON_SECRET> on cron requests.
# -----------------------------------------------------------------------------

CRON_SECRET=""
